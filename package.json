{
  "version": "1.0.0",
  "description": "80s inspired drum machine",
  "homepage": "https://metzgerdev.github.io/Drum-Machine/",
  "name": "Drum Machine",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "bun run scripts/build.ts --production",
    "build:dev": "bun run scripts/build.ts",
    "dev": "bun run scripts/dev.ts",
    "predeploy": "bun run build",
    "deploy": "gh-pages -d dist",
    "serve": "bun run scripts/dev.ts",
    "watch": "bun --watch scripts/build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "gh-pages": "^6.3.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "graphql": "^16.13.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
